# Copy to /opt/ppt-dataset-6m/.env on the droplet

# PostgreSQL (required in production)
DATABASE_URL=postgresql://ppt_urls:CHANGE_ME@localhost:5432/ppt_urls

# Data directory (manifests, audit logs, progress reports)
DATA_DIR=data

# Target qualified URL count
TARGET_COUNT=6000000

# Use production-tuned concurrency settings
CONFIG_PATH=config/config.prod.yaml

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/ppt-discovery/pipeline.log
